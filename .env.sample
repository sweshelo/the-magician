# Supabase無効化モード（ローカル開発・セルフホスティング用）
# trueに設定するとSupabaseを使った機能をすべて無効化（認証・ランキング等）
DISABLE_SUPABASE=false

# Discordログイン無効化モード（セルフホスティング用）
# trueに設定すると /login へのアクセスを /entrance にリダイレクト
DISABLE_DISCORD_LOGIN=true

# Supabase設定
# Supabaseダッシュボードから取得: https://supabase.com/dashboard
NEXT_PUBLIC_IMAGE_SELF_HOSTING=false
NEXT_PUBLIC_IMAGE_SIZE=normal
NEXT_PUBLIC_SECURE_CONNECTION=true
NEXT_PUBLIC_SERVER_HOST=localhost:5000
NEXT_PUBLIC_SOUNDPATH=/sound/se
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# サーバーサイド専用（管理者ダッシュボードのRLS回避用）
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
